# Copy this file to backend/.env and fill in the values.
# Never commit .env to version control.

# ── Auth ───────────────────────────────────────────────────────────────────────
# Secret key for JWT signing. Generate a strong value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET=change-me-use-a-long-random-string-in-production

# ── Database ───────────────────────────────────────────────────────────────────
# For local dev without Docker, leave unset — defaults to SQLite (backend/test.db).
# For Docker Compose, docker-compose.yml injects this automatically from the values below.
# For cloud, point this at your managed PostgreSQL instance.
DATABASE_URL=postgresql+asyncpg://blog_user:blog_pass@localhost:5432/blog_db

# ── CORS ───────────────────────────────────────────────────────────────────────
# URL of the frontend — used to configure CORS allowed origins.
# In Docker Compose this is overridden by docker-compose.yml.
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL container credentials (used by docker-compose db service) ───────
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=blog_pass
POSTGRES_DB=blog_db

# ── hCaptcha ───────────────────────────────────────────────────────────────────
# Flip to "true" to enforce hCaptcha verification on /auth/register and /auth/jwt/login.
HCAPTCHA_ENABLED=false
# Get this from https://dashboard.hcaptcha.com/. For local testing use the
# official hCaptcha sandbox secret: 0x0000000000000000000000000000000000000000
HCAPTCHA_SECRET=
# NOTE: the matching public site key goes in frontend/.env.local (see frontend/.env.example).
